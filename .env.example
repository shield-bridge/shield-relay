# shield-relay configuration — copy to `.env` and edit.
#
#   cp .env.example .env
#
# The relay reads ONLY these environment variables (single source of truth:
# src/config/schema.ts). Lines you leave commented use the safe defaults shown.
#
# HOW THIS FILE IS LOADED:
#   - The relay CLI auto-loads a `.env` in the working directory for EVERY command —
#     `npm start`, `npm run dev`, and the `relay` binary (see src/config/loadEnv.ts).
#   - Docker Compose injects it via `env_file:` in compose.yaml.
# A variable already set in your SHELL (or by Compose) takes precedence over the same key here.
#
# DO NOT put DATA_DIR or POOL_FILE here — compose.yaml sets those to the correct
# in-container values (/data is the named volume; /run/secrets/pool.json is the ro mount).

# ── Image (override to pin a digest for reproducible deploys) ───────────────
# RELAY_IMAGE=ghcr.io/andrewkishino/shield-relay:latest
# RELAY_IMAGE=ghcr.io/andrewkishino/shield-relay@sha256:<digest>

# ── Network ─────────────────────────────────────────────────────────────────
TEZOS_NETWORK=mainnet
# Override the RPC if you run your own node (recommended for reliability).
# Defaults: mainnet=https://tezos-mainnet.octez.io  shadownet=https://tezos-shadownet.octez.io
# TEZOS_RPC_URL=https://tezos-shadownet.octez.io
# Override only if you target a non-default factory contract.
# SHIELD_BRIDGE_CONTRACT=KT1WqGXxe5Anam6Hm6zQqGmaXdtZrzZRynnw

# ── Workers & memory ────────────────────────────────────────────────────────
# The relay is a lightweight tz1 broadcaster (no ZK proving) — each worker is just an
# RPC client + signer, so RAM is modest and barely grows with worker count.
# Each job is handled end-to-end by ONE worker (both phases share its tz1, so the fee it
# receives self-funds the gas it spends). >1 worker buys PARALLELISM (N concurrent jobs),
# not unlinkability. Must be ≤ the workers in your pool.json.
WORKER_COUNT=2

# On-chain registry listing (optional — only for `relay registry register/update`).
# Your public https origin, serving /info + /.well-known/shield-relay.json:
# RELAY_PUBLIC_URL=https://relay.example.com
# Override the per-network registry KT1 (defaults are baked in per TEZOS_NETWORK):
# RELAY_REGISTRY_CONTRACT=KT1...

# Container memory sizing. A few hundred MB is plenty regardless of WORKER_COUNT.
MEM_RESERVATION=256m
MEM_LIMIT=512m

# ── Security ────────────────────────────────────────────────────────────────
# Require the per-job shared secret on submit/subscribe. Keep TRUE in production
# — it stops third parties from snooping on or hijacking another user's job.
REQUIRE_JOB_SECRET=true

# Requests/min per client IP before HTTP 429 (@fastify/rate-limit; loopback exempt).
# RATE_LIMIT_RPM=120
# Set true ONLY behind a trusted reverse proxy (e.g. the Caddy profile) so the rate
# limiter keys on X-Forwarded-For. Leave false when PORT is exposed directly.
# TRUST_PROXY=false

# Log client IPs (privacy trade-off; off by default for a privacy relay).
# RETAIN_CLIENT_IPS=false

# ── Economics ───────────────────────────────────────────────────────────────
# Legacy flat fee (mutez, 1 XTZ = 1_000_000) — quoted to clients that don't send
# a txCount. Also the dark default for the schedule base below.
# PAYMENT_AMOUNT_MUTEZ=1000000

# Quantized fee schedule (FEE_SCHEDULE.md). DEFAULTS REPRODUCE THE FLAT FEE EXACTLY
# (ships dark). Uncomment the recommended values to enable per-size pricing —
# fee(n) = quantizeUp(BASE + PER_TX×n, QUANTUM). Singles get cheaper (~0.5 XTZ),
# large batches stop being injected at a loss. LEGACY_FLAT_MAX_TXS caps how many
# sapling txs a no-txCount (legacy) client may submit on the flat fee (0 = no cap);
# set it to close the batch-cap griefing vector for un-upgraded clients.
# Recommended values target a ≥20% profit floor on a worst-case (all-max-fragmentation)
# batch, from the FEE_SCHEDULE.md §6.1 mainnet sweep (worst per-op cost ~215k µtz). Fees:
# 1 tx → 0.75, 5 → 1.75, 10 → 3.0 XTZ. See §6.1 for the dial if you'd rather optimize for
# typical jobs (lower fees, thinner margin on heavy batches).
# FEE_BASE_MUTEZ=300000
# FEE_PER_TX_MUTEZ=270000
# FEE_QUANTUM_MUTEZ=250000
# LEGACY_FLAT_MAX_TXS=5

# Low-gas watchdog: alert + flag a worker whose tz1 falls below this (XTZ). There is NO
# auto-refill — under unshield payments the fee lands on the worker's tz1, so workers
# self-fund; a low balance means seed it manually or the fee is set below gas cost.
# LOW_BALANCE_XTZ=5
# BALANCE_CHECK_INTERVAL_MS=21600000   # 6h
# The watchdog only alerts when a worker first drops below the threshold (and logs on
# recovery); a still-low worker re-alerts at most once per this window, so it won't spam.
# LOW_BALANCE_REALERT_MS=86400000      # 24h

# ── Confirmations ───────────────────────────────────────────────────────────
# Blocks to wait before trusting phase-1 payment / phase-2 user tx.
# CONFIRMATIONS_PHASE1=2
# CONFIRMATIONS_PHASE2=1

# ── Storage & lifecycle ─────────────────────────────────────────────────────
# Keep DATA_DIR (relay.db) on a LOCAL filesystem — NFS/SMB corrupt SQLite's WAL and
# break the single-writer instance lock. compose.yaml already uses a local volume.

# How long a finished/expired job row is retained (seconds).
# JOB_TTL_SECONDS=3600

# Max time to let in-flight work finish during shutdown drain (ms).
# DRAIN_TIMEOUT_MS=120000

# ── Server ──────────────────────────────────────────────────────────────────
# In-container port the relay listens on. Leave 8080 — compose maps it.
# PORT=8080
# Host port to publish (homelab direct-access path).
HOST_PORT=8080
# Bind only to loopback if Caddy/another proxy fronts the relay: RELAY_BIND=127.0.0.1
RELAY_BIND=0.0.0.0

# ── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info
# Optional: POST alerts (low gas, drain stalls) to a webhook.
# ALERT_WEBHOOK_URL=https://hooks.example.com/your-relay
# /metrics is OFF by default — per-worker gas balance + queue depth are
# deanonymization-relevant metadata for a privacy relay, and the homelab path
# publishes 8080 directly. Set a token to enable it; your scraper then sends
# `Authorization: Bearer <token>`. Leave unset (or front with Caddy) otherwise.
# METRICS_TOKEN=change-me-to-a-long-random-string

# ── Caddy (only used by the `tls` profile) ──────────────────────────────────
# With a real domain: set your hostname and open 80+443.
DOMAIN=relay.example.com
# No domain? Use  DOMAIN=:443  for Caddy's internal self-signed TLS, or skip the
# tls profile entirely and use plain :8080.
# Let's Encrypt uses this email for expiry notices (recommended).
# ACME_EMAIL=you@example.com
